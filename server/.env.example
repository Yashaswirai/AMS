# Server configuration
PORT=5000
NODE_ENV=development
ENABLE_RATE_LIMITER=false
CLIENT_URL=http://localhost:5173

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/frams

# JWT Credentials
JWT_ACCESS_SECRET=your_jwt_access_token_secret_here_make_it_long_and_secure
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=your_jwt_refresh_token_secret_here_make_it_long_and_secure
JWT_REFRESH_EXPIRY=7d

# ImageKit Config
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=your_imagekit_url_endpoint

# Email Config (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# Google Generative AI (Gemini) Config
GEMINI_API_KEY=your_gemini_api_key_here

# CV FastAPI Service URL
CV_API_URL=http://localhost:8000

# Geolocation verification parameters (optional boundary checks for QR attendance)
# Example coordinates (New Delhi)
GEOLOCATION_LAT=28.6139
GEOLOCATION_LNG=77.2090
GEOLOCATION_RADIUS=100
