# ─── Application ────────────────────────────────────────────────────────────────
APP_NAME=FRAMS-CV-API
APP_VERSION=1.0.0
DEBUG=true
PORT=8000
HOST=0.0.0.0

# ─── Paths ────────────────────────────────────────────────────────────────────
EMBEDDINGS_DIR=./data/embeddings
MODELS_DIR=./models
DATASET_DIR=./data

# ─── Face Recognition ────────────────────────────────────────────────────────
FACE_RECOGNITION_THRESHOLD=0.6
LIVENESS_BLINK_THRESHOLD=0.21
MIN_FACE_SIZE=50
MAX_EMBEDDING_AGE_DAYS=365

# ─── MongoDB (optional – used by main backend) ────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=frams_db

# ─── ML ─────────────────────────────────────────────────────────────────────
ML_RANDOM_STATE=42
CV_FOLDS=5
